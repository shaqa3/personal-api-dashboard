# Copy to .env and fill in whatever you have. Every source is optional —
# a source with no credentials simply reports status "disabled" and the
# rest of the dashboard keeps working.

# How often the scheduler refreshes every source, in seconds.
REFRESH_INTERVAL_SECONDS=300

# Comma-separated list of allowed origins for your portfolio site.
# Use * while developing.
CORS_ORIGINS=*

# --- GitHub (no token required for public data; token raises rate limits) ---
GITHUB_USERNAME=
GITHUB_TOKEN=

# --- WakaTime (Settings -> API Key) ---
WAKATIME_API_KEY=

# --- Spotify (needs a one-time OAuth dance to get a refresh token) ---
# See README "Getting a Spotify refresh token".
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# --- Strava (OAuth refresh token; scope activity:read) ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
